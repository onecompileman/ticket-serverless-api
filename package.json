{
  "name": "ticket-serverless-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "unit": "jest --config jest.config.ts",
    "lint": "eslint \"src/**/*.ts\" --quiet --fix",
    "compile": "tsc -p tsconfig.json",
    "test": "npm run compile && npm run unit",
