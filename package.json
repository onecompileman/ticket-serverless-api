    "@middy/core": "^6.4.5",
    "@middy/http-cors": "^6.4.5",
    "@middy/http-json-body-parser": "^6.4.5",
    "@middy/validator": "^6.4.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jwk-to-pem": "^2.0.3",
    "@types/nodemailer": "^8.0.0",
    "ajv": "^8.18.0",
    "aws-lambda": "^1.0.7",
    "esbuild": "^0.14.14",
    "jsonwebtoken": "^9.0.3",
    "jwk-to-pem": "^2.0.7",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
